# ─────────────────────────────────────────────────────────────────────────────
# Photo Organizer — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values before running:
#   cp .env.example .env
#   docker compose up -d
# ─────────────────────────────────────────────────────────────────────────────


# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── Laravel Application ──────────────────────────────────────────────────────
APP_NAME="Photo Organizer"
APP_ENV=production
APP_KEY=                           # Generate: docker run --rm ghcr.io/kwasii1/face-pipeline-ui:latest php artisan key:generate --show
APP_DEBUG=false
APP_URL=http://localhost

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=face_pipeline
DB_USERNAME=postgres
DB_PASSWORD=password

REDIS_HOST=redis
REDIS_PORT=6379
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=reverb

# ── Reverb (WebSockets) ──────────────────────────────────────────────────────
REVERB_APP_ID=843193
REVERB_APP_KEY=change_me_32_chars   # Generate: openssl rand -hex 16
REVERB_APP_SECRET=change_me_32_chars # Generate: openssl rand -hex 16
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# ── FastAPI Face Pipeline ────────────────────────────────────────────────────
FASTAPI_BASE_URL=http://face-pipeline:8001

# ── Shared Storage ───────────────────────────────────────────────────────────
SHARED_STORAGE_PATH=/shared-storage

# ── Migrations ───────────────────────────────────────────────────────────────
RUN_MIGRATIONS=true

# ── Face Pipeline Tuning (optional) ──────────────────────────────────────────
FACE_PIPELINE_INSIGHTFACE_MODEL_NAME=buffalo_l
FACE_PIPELINE_MIN_DETECTION_SCORE=0.5
FACE_PIPELINE_MIN_FACE_SIZE_PX=40
FACE_PIPELINE_MIN_RELATIVE_FACE_SIZE=0.015
FACE_PIPELINE_MATCH_CONFIDENCE_THRESHOLD=0.62
FACE_PIPELINE_HDBSCAN_MIN_CLUSTER_SIZE=2
FACE_PIPELINE_HDBSCAN_MIN_SAMPLES=2
FACE_PIPELINE_FACE_CROPS_DIR=/shared-storage/face_crops
